# MongoDB Atlas connection string (required)
# Example: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URL=

# Database name (default: akr_trust)
DB_NAME=akr_trust

# Comma-separated allowed origins for CORS (default: *)
# Local dev example: http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
